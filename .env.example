# GershonCRM environment variables
# Copy to `.env` on the VPS and fill real values. NEVER commit the real .env.

NODE_ENV=production
PORT=5000

# postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://gershoncrm_app:CHANGE_ME@localhost:5432/gershoncrm

# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME

# From 1Password "GershonCRM Deploy"
OPENAI_API_KEY=sk-CHANGE_ME

# Reserved for post-launch fixes:
# LOAD_INITIAL_DATA=false
